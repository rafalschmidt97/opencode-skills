# SearXNG Search Skill - Configuration
#
# Override any value via environment variables.

# Port for the MCP server on localhost.
# Env override: SEARXNG_MCP_PORT
SEARXNG_MCP_PORT=32123

# Container runtime compose command. Leave empty for auto-detection.
# Auto-detection tries "docker compose" first, then "podman compose".
# Env override: COMPOSE_CMD
# Examples: "docker compose", "podman compose"
COMPOSE_CMD=
